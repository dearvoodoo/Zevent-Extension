{
  "name": "ZEVENT",
  "description": "ZEVENT est une extension qui affiche les streamers du zevent et leurs informations.",
  "version": "2026.2",
  "author": "VooDoo",
  "icons": {
    "16": "assets/images/zevent16.png",
    "32": "assets/images/zevent32.png",
    "48": "assets/images/zevent48.png",
    "128": "assets/images/zevent128.png"
  },
  "permissions": [
    "notifications",
    "alarms",
    "storage",
    "https://*.zevent.fr/*",
    "https://api.the-coven.fr/*",
    "https://place-api.zevent.fr/*",
    "https://clips.zevent.fr/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "manifest_version": 2,
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/images/zevent16.png",
      "32": "assets/images/zevent32.png",
      "48": "assets/images/zevent48.png",
      "128": "assets/images/zevent128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "zevent@the-coven.fr",
      "strict_min_version": "109.0"
    }
  }
}